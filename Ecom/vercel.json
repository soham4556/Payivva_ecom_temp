{
  "version": 2,
  "builds": [
    {
      "src": "ecom/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.js" },
    { "src": "/assets/(.*)", "dest": "ecom/assets/$1" },
    { "src": "/(.*)\\.(js|css|png|jpg|svg|ico)", "dest": "ecom/$1.$2" },
    { "src": "/(.*)", "dest": "ecom/index.html" }
  ]
}
